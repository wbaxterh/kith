# Copy to `.env` and fill in.

# Required — your ElevenLabs API key.
ELEVENLABS_API_KEY=

# Required — voice ID to synthesize with.
# Pick one from https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=

# Optional — model override. Defaults to eleven_v3.
# Audio tags like [laughs] / [giggles] (see DEFAULT_LAUGH_TAGS) ONLY work
# on eleven_v3. Older models speak the tag literally — don't downgrade
# unless you also rebuild your slang without tag-emitting entries.
# ELEVENLABS_MODEL_ID=eleven_v3

# Optional — server port. Defaults to 3030.
# PORT=3030
