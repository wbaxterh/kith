# Copy to `.env` and fill in.

# Required — your ElevenLabs API key.
ELEVENLABS_API_KEY=

# Required — voice ID to synthesize with.
# Pick one from https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=

# Optional — model override. Defaults to eleven_multilingual_v2.
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Optional — server port. Defaults to 3030.
# PORT=3030
